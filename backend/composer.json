{
  "name": "umsa/rayos-cosmicos-backend",
  "version": "0.1.0-beta",
  "description": "Backend del Sistema de Monitoreo de Rayos Cósmicos - UMSA",
  "type": "library",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "monolog/monolog": "^3.5",
    "doctrine/orm": "^2.18",
    "nesbot/carbon": "^2.72",
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public",
    "test": "phpunit",
    "lint": "phpcs --standard=PSR12 src/"
  }
}
