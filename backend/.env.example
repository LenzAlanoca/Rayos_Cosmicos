APP_NAME="Rayos Cósmicos Backend"
APP_VERSION="0.1.0-beta"
APP_ENV="development"
APP_DEBUG=true

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rayos_cosmicos
DB_USER=root
DB_PASS=

# API
API_PORT=8000
API_HOST=localhost

# Configuración de sensores
SENSOR_UPDATE_INTERVAL=60

# Logging
LOG_LEVEL=info
LOG_FILE=storage/logs/app.log
